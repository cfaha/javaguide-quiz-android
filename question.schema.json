{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "JavaGuide Quiz Question",
  "type": "object",
  "required": ["id", "type", "category", "stem", "answers", "explanation", "source"],
  "properties": {
    "id": { "type": "string" },
    "type": { "type": "string", "enum": ["single", "multi", "blank"] },
    "category": { "type": "string" },
    "subCategory": { "type": "string" },
    "stem": { "type": "string" },
    "options": {
      "type": "array",
      "items": { "type": "string" }
    },
    "answers": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "explanation": { "type": "string" },
    "difficulty": { "type": "integer", "minimum": 1, "maximum": 5 },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "source": {
      "type": "object",
      "required": ["repo", "path"],
      "properties": {
        "repo": { "type": "string" },
        "path": { "type": "string" },
        "anchor": { "type": "string" }
      }
    }
  }
}
